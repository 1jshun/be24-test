pipeline {
    agent any

    environment {
        DOCKER_CREDS = credentials('dockerhub-creds')
        IMAGE_NAME = 'nahune/mimingfront'
        TAG = "0.${env.BUILD_NUMBER}"
    }

    stages {
        stage('1. Checkout Code') {
            steps {
                git branch: 'main', url: 'https://github.com/1jshun/be24-test.git'
            }
        }

        stage('2. Build Frontend App') {
            steps {
                dir('miming') {
                    sh 'npm install'
                    sh 'npm run build'
                }
            }
        }

        stage('3. Build & Push Docker Image') {
            steps {
                dir('miming') {
                    sh "docker build -t ${IMAGE_NAME}:${TAG} ."

                    sh "echo \$DOCKER_CREDS_PSW | docker login -u \$DOCKER_CREDS_USR --password-stdin"
                    sh "docker push ${IMAGE_NAME}:${TAG}"
                }
            }
        }

        stage('4. Deploy to Kubernetes') {
            steps {
                sh "kubectl set image deployment/frontend-deployment frontend=${IMAGE_NAME}:${TAG}"
            }
        }
    }

    post {
        always {
            sh "docker image prune -f"
        }
    }
}